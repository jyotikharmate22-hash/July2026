{
  "name": "playwright-cucumber-ts-framework",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "cucumber-js",
    "test:debug": "cucumber-js --publish-quiet --retry 0",
    "playwright:install": "npx playwright install",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "postinstall": "npx playwright install --with-deps"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.0",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@cucumber/cucumber": "^9.0.0",
    "allure-commandline": "^2.13.9",
    "allure-cucumberjs": "^2.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "tsconfig-paths": "^4.0.0"
  }
}
